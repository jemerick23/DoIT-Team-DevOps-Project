pipeline {
    agent any

    stages {
        stage('Install') {
            steps {
                bat 'npm install'
            }
        }

        stage('Run Server') {
            steps {
                bat 'start /B node server.js'
            }
        }

        stage('Verify') {
            steps {
                bat 'curl http://localhost:3000/api/tasks'
            }
        }
    }
}

