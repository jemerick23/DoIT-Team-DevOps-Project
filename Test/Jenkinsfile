pipeline {
    agent any

    stages {

        stage('Verify Node') {
            steps {
                bat 'node -v'
                bat 'npm -v'
            }
        }

        stage('Show Scripts') {
            steps {
                bat 'npm run'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
            }
        }

        stage('Run Tests') {
            steps {
                bat 'cd Test && npm test'
            }
        }

        stage('Build Successful') {
            steps {
                bat 'echo DoIT Pipeline Passed'
            }
        }
    }
}

