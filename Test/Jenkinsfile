pipeline {
    agent any

    stages {

        stage('Verify Node') {
            steps {
                bat 'node -v'
                bat 'npm -v'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
            }
        }

        stage('Install Playwright Browsers') {
            steps {
                bat 'npx playwright install --with-deps'
            }
        }

        stage('Start Backend') {
            steps {
                bat 'start /B node backend/server.js'
                bat 'node -e "setTimeout(() => {}, 8000)"'
            }
        }

        stage('E2E Tests') {
            steps {
                bat 'npm run test:e2e'
            }
        }

        stage('Build Successful') {
            steps {
                bat 'echo DoIT Pipeline Passed'
            }
        }
    }
}

