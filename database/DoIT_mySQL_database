-- DoIT Project MySQL Database
-- Import this file into MySQL Workbench, phpMyAdmin, or the MySQL command line.
--
-- MySQL command line example:
-- mysql -u root -p < doit_mysql_schema.sql

DROP DATABASE IF EXISTS doit_project;
CREATE DATABASE doit_project;
USE doit_project;

CREATE TABLE roles (
    role_id INT AUTO_INCREMENT PRIMARY KEY,
    role_name VARCHAR(100) NOT NULL UNIQUE,
    description TEXT
);

CREATE TABLE users (
    user_id INT AUTO_INCREMENT PRIMARY KEY,
    first_name VARCHAR(100) NOT NULL,
    last_name VARCHAR(100) NOT NULL,
    email VARCHAR(255) NOT NULL UNIQUE,
    role_id INT,
    created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT fk_users_roles
        FOREIGN KEY (role_id) REFERENCES roles(role_id)
        ON DELETE SET NULL
);

CREATE TABLE projects (
    project_id INT AUTO_INCREMENT PRIMARY KEY,
    project_name VARCHAR(150) NOT NULL UNIQUE,
    description TEXT,
    status VARCHAR(50) NOT NULL DEFAULT 'Planning',
    start_date DATE,
    target_end_date DATE,
    created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE sprints (
    sprint_id INT AUTO_INCREMENT PRIMARY KEY,
    project_id INT NOT NULL,
    sprint_name VARCHAR(150) NOT NULL,
    start_date DATE NOT NULL,
    end_date DATE NOT NULL,
    goal TEXT,
    status VARCHAR(50) NOT NULL DEFAULT 'Planned',
    CONSTRAINT fk_sprints_projects
        FOREIGN KEY (project_id) REFERENCES projects(project_id)
        ON DELETE CASCADE
);

CREATE TABLE tasks (
    task_id INT AUTO_INCREMENT PRIMARY KEY,
    project_id INT NOT NULL,
    sprint_id INT,
    assigned_to INT,
    title VARCHAR(200) NOT NULL,
    description TEXT,
    priority VARCHAR(50) NOT NULL DEFAULT 'Medium',
    status VARCHAR(50) NOT NULL DEFAULT 'Backlog',
    story_points INT,
    due_date DATE,
    created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP NULL DEFAULT NULL,
    CONSTRAINT fk_tasks_projects
        FOREIGN KEY (project_id) REFERENCES projects(project_id)
        ON DELETE CASCADE,
    CONSTRAINT fk_tasks_sprints
        FOREIGN KEY (sprint_id) REFERENCES sprints(sprint_id)
        ON DELETE SET NULL,
    CONSTRAINT fk_tasks_users
        FOREIGN KEY (assigned_to) REFERENCES users(user_id)
        ON DELETE SET NULL
);

CREATE TABLE agile_poker_sessions (
    session_id INT AUTO_INCREMENT PRIMARY KEY,
    project_id INT NOT NULL,
    sprint_id INT,
    session_name VARCHAR(150) NOT NULL,
    session_date DATE NOT NULL,
    notes TEXT,
    CONSTRAINT fk_poker_sessions_projects
        FOREIGN KEY (project_id) REFERENCES projects(project_id)
        ON DELETE CASCADE,
    CONSTRAINT fk_poker_sessions_sprints
        FOREIGN KEY (sprint_id) REFERENCES sprints(sprint_id)
        ON DELETE SET NULL
);

CREATE TABLE agile_poker_votes (
    vote_id INT AUTO_INCREMENT PRIMARY KEY,
    session_id INT NOT NULL,
    task_id INT NOT NULL,
    user_id INT NOT NULL,
    estimate_value INT NOT NULL,
    comments TEXT,
    voted_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT fk_votes_sessions
        FOREIGN KEY (session_id) REFERENCES agile_poker_sessions(session_id)
        ON DELETE CASCADE,
    CONSTRAINT fk_votes_tasks
        FOREIGN KEY (task_id) REFERENCES tasks(task_id)
        ON DELETE CASCADE,
    CONSTRAINT fk_votes_users
        FOREIGN KEY (user_id) REFERENCES users(user_id)
        ON DELETE CASCADE
);

CREATE TABLE meeting_notes (
    note_id INT AUTO_INCREMENT PRIMARY KEY,
    project_id INT NOT NULL,
    meeting_date DATE NOT NULL,
    topic VARCHAR(200) NOT NULL,
    attendees TEXT,
    decisions TEXT,
    action_items TEXT,
    created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT fk_meeting_notes_projects
        FOREIGN KEY (project_id) REFERENCES projects(project_id)
        ON DELETE CASCADE
);

CREATE TABLE audit_log (
    audit_id INT AUTO_INCREMENT PRIMARY KEY,
    table_name VARCHAR(100) NOT NULL,
    record_id INT NOT NULL,
    action VARCHAR(50) NOT NULL,
    changed_by INT,
    change_summary TEXT,
    changed_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT fk_audit_users
        FOREIGN KEY (changed_by) REFERENCES users(user_id)
        ON DELETE SET NULL
);

CREATE TABLE messages (
    message_id INT AUTO_INCREMENT PRIMARY KEY,
    user_id INT NOT NULL,
    message TEXT NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (user_id) REFERENCES users(user_id)
);

