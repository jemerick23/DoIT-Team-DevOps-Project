-- Useful report query: all project tasks with assigned users
SELECT 
    t.task_id,
    t.title,
    t.priority,
    t.status,
    t.story_points,
    CONCAT(u.first_name, ' ', u.last_name) AS assigned_to,
    s.sprint_name
FROM tasks t
LEFT JOIN users u ON t.assigned_to = u.user_id
LEFT JOIN sprints s ON t.sprint_id = s.sprint_id
ORDER BY t.task_id;

-- Useful report query: agile poker average estimates by task
SELECT
    t.title,
    ROUND(AVG(v.estimate_value), 2) AS average_estimate,
    COUNT(v.vote_id) AS vote_count
FROM tasks t
LEFT JOIN agile_poker_votes v ON t.task_id = v.task_id
GROUP BY t.task_id, t.title
ORDER BY t.task_id;
